{% extends 'base.html.twig' %}

{% block title %}Paiement réussi — Maison UMU{% endblock %}

{% block body %}
<div class="umu-auth">
    <div class="umu-auth__panel" style="text-align:center;">
        <div class="umu-auth__brand">
            <img src="{{ asset(brand_logo_path) }}" alt="Maison UMU">
        </div>
        <h1>Paiement réussi</h1>
        <div class="umu-alert umu-alert--success">
            Merci pour votre commande. Un e-mail de confirmation vous sera envoyé.
        </div>
        <a class="umu-btn umu-btn--primary" href="{{ path('app_home_page') }}">Retour à la boutique</a>
    </div>
</div>
{% endblock %}
