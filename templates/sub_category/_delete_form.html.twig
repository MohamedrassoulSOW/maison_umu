<form method="post" action="{{ path('app_sub_category_delete', { id: sub_category.id }) }}" onsubmit="return confirm('Souhaitez-vous vraiment supprimer cette sous-catégorie ?');" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ sub_category.id) }}">
    <button type="submit" class="umu-btn umu-btn--danger umu-btn--sm">Supprimer</button>
</form>
