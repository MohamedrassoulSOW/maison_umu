{% extends 'base.html.twig' %}

{% block title %}À propos — {{ brand_name }}{% endblock %}

{% block body %}
<section class="umu-content">
    <header class="umu-content__intro">
        <img class="umu-content__logo" src="{{ asset(brand_logo_path) }}" alt="{{ brand_name }}">
        <p class="umu-content__eyebrow">{{ brand_tagline }}</p>
        <h1>À propos de {{ brand_name }}</h1>
        <p class="umu-content__lead">{{ site.aboutLead }}</p>
    </header>

    <div class="umu-content__grid">
        <article class="umu-content__block">
            <h2>{{ site.aboutBlock1Title }}</h2>
            <p>{{ site.aboutBlock1Text }}</p>
        </article>

        <article class="umu-content__block">
            <h2>{{ site.aboutBlock2Title }}</h2>
            <p>{{ site.aboutBlock2Text }}</p>
        </article>

        <article class="umu-content__block">
            <h2>{{ site.aboutBlock3Title }}</h2>
            <p>{{ site.aboutBlock3Text }}</p>
        </article>
    </div>

    <div class="umu-content__cta">
        <a class="umu-btn umu-btn--primary" href="{{ path('app_home_page') }}">Explorer la boutique</a>
        <a class="umu-btn umu-btn--ghost" href="{{ path('app_contact') }}">Nous contacter</a>
    </div>
</section>
{% endblock %}
