{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — {{ brand_name }}{% endblock %}

{% block body %}
<div class="umu-auth">
    <div class="umu-auth__panel">
        <div class="umu-auth__brand">
            <img src="{{ asset(brand_logo_path|default('images/logo.jpeg')) }}" alt="{{ brand_name }}">
        </div>
        <h1>Mot de passe oublié</h1>
        <p style="text-align:center; color:rgba(26,33,28,0.65); margin-top:-0.5rem; margin-bottom:1.25rem;">
            Indiquez votre email pour recevoir un lien de réinitialisation.
        </p>

        {{ form_start(requestForm, { attr: { 'data-turbo': 'false' } }) }}
            <label for="{{ requestForm.email.vars.id }}">Email</label>
            {{ form_widget(requestForm.email) }}
            {{ form_errors(requestForm.email) }}

            <button class="btn" type="submit">Envoyer le lien</button>
        {{ form_end(requestForm) }}

        <p style="text-align:center; margin-top:1.25rem; font-size:0.92rem;">
            <a href="{{ path('app_login') }}">Retour à la connexion</a>
        </p>
    </div>
</div>
{% endblock %}
