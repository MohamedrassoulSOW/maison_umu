{% extends 'dashboard/layout.html.twig' %}

{% block title %}{{ product.name }} — Dashboard{% endblock %}
{% block dash_title %}Fiche produit{% endblock %}
{% block dash_subtitle %}{{ product.name }}{% endblock %}

{% block dash_actions %}
    <a href="{{ path('app_product_stock_add_history', { id: product.id }) }}" class="umu-btn umu-btn--ghost umu-btn--sm">Historique stock</a>
    <a href="{{ path('app_product_edit', { id: product.id }) }}" class="umu-btn umu-btn--primary umu-btn--sm">Modifier</a>
    <a href="{{ path('app_product_index') }}" class="umu-btn umu-btn--ghost umu-btn--sm">Retour</a>
{% endblock %}

{% block dash_body %}
<div class="dash-card">
    <div class="dash-detail">
        {% if product.image %}
            <div class="dash-detail__row">
                <div class="dash-detail__label">Image</div>
                <div class="dash-detail__value">
                    <div class="dash-detail__media">
                        <img src="{{ asset('uploads/images/' ~ product.image) }}" alt="{{ product.name }}">
                    </div>
                </div>
            </div>
        {% endif %}
        <div class="dash-detail__row">
            <div class="dash-detail__label">ID</div>
            <div class="dash-detail__value">{{ product.id }}</div>
        </div>
        <div class="dash-detail__row">
            <div class="dash-detail__label">Nom</div>
            <div class="dash-detail__value"><strong>{{ product.name }}</strong></div>
        </div>
        <div class="dash-detail__row">
            <div class="dash-detail__label">Description</div>
            <div class="dash-detail__value">{{ product.description }}</div>
        </div>
        <div class="dash-detail__row">
            <div class="dash-detail__label">Prix</div>
            <div class="dash-detail__value">{{ product.price }} CFA</div>
        </div>
        <div class="dash-detail__row">
            <div class="dash-detail__label">Stock</div>
            <div class="dash-detail__value">
                {% if product.stock > 0 %}
                    <span class="dash-badge dash-badge--ok">{{ product.stock }} en stock</span>
                {% else %}
                    <span class="dash-badge dash-badge--alert">Épuisé</span>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="dash-form__actions">
        <a href="{{ path('app_product_stock_add', { id: product.id }) }}" class="umu-btn umu-btn--primary umu-btn--sm">Ajouter du stock</a>
        <a href="{{ path('app_product_edit', { id: product.id }) }}" class="umu-btn umu-btn--ghost umu-btn--sm">Modifier</a>
        <form method="post" action="{{ path('app_product_delete', { id: product.id }) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce produit ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
            <button type="submit" class="umu-btn umu-btn--danger umu-btn--sm">Supprimer</button>
        </form>
    </div>
</div>
{% endblock %}
