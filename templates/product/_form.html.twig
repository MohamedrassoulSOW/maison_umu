{{ form_start(form, { attr: { class: 'dash-form', 'data-turbo': 'false' } }) }}
    {{ form_row(form.name, { attr: { class: 'form-control' }, label: 'Nom du produit' }) }}
    {{ form_row(form.description, { attr: { class: 'form-control' }, label: 'Description' }) }}
    {{ form_row(form.Price, { attr: { class: 'form-control' }, label: 'Prix (CFA)' }) }}
    {% if form.stock is defined %}
        {{ form_row(form.stock, { attr: { class: 'form-control' }, label: 'Stock initial' }) }}
    {% endif %}
    {{ form_row(form.subcategories, { attr: { class: 'form-select' }, label: 'Sous-catégorie' }) }}
    {{ form_row(form.image, { attr: { class: 'form-control' }, label: 'Image' }) }}

    <div class="dash-form__actions">
        <button type="submit" class="umu-btn umu-btn--primary">
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}
