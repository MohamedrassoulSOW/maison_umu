<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <script>
            (function () {
                try {
                    var saved = localStorage.getItem('umu-theme');
                    var dark = saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
                    document.documentElement.dataset.theme = dark ? 'dark' : 'light';
                    document.documentElement.style.colorScheme = dark ? 'dark' : 'light';
                } catch (e) {
                    document.documentElement.dataset.theme = 'light';
                }
            })();
        </script>
        <title>{% block title %}{{ brand_name|default('Maison UMU') }}{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        {# CSS boutique hors Asset Mapper : évite les 404 /assets/styles/app-XXXX.css en prod #}
        <link rel="stylesheet" href="{{ asset('css/umu.css') }}">
        {% set favicon_path = brand_logo_path|default('images/logo.jpeg') %}
        {% set favicon_ext = favicon_path|split('.')|last|lower %}
        {% set favicon_type = favicon_ext in ['jpg', 'jpeg'] ? 'image/jpeg' : (favicon_ext == 'png' ? 'image/png' : (favicon_ext == 'webp' ? 'image/webp' : 'image/jpeg')) %}
        <link rel="icon" href="{{ asset(favicon_path) }}" type="{{ favicon_type }}">
        <link rel="apple-touch-icon" href="{{ asset(favicon_path) }}">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        {% block page_styles %}{% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% block nav %}
            {{ render(path('app_menu')) }}
        {% endblock %}

        {% include 'leyouts/_flash_message.html.twig' %}

        <main class="umu-main {% block main_class %}{% endblock %}">
            {% block body %}{% endblock %}
        </main>

        {% block footer %}
            {{ render(path('app_footer')) }}
        {% endblock %}

        {% include 'leyouts/_product_modal_shell.html.twig' %}

        {# Hors navbar : flottant en haut à droite, juste sous le header #}
        <button type="button"
                class="umu-theme-toggle umu-theme-toggle--float"
                data-umu-theme-toggle
                aria-label="Activer le mode sombre"
                title="Mode sombre">
            <svg class="umu-theme-toggle__moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278"/>
            </svg>
            <svg class="umu-theme-toggle__sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>
            </svg>
        </button>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        {# UI critique hors importmap : catégories, profil, favoris, thème — OK même sans asset-map:compile #}
        <script src="{{ asset('js/umu-ui.js') }}" defer></script>
        <script>
            (function () {
                function setMenuOpen(open) {
                    var header = document.querySelector('[data-umu-nav]');
                    var panel = document.querySelector('[data-umu-nav-panel]');
                    var toggle = document.querySelector('[data-umu-nav-toggle]');
                    var backdrop = document.querySelector('[data-umu-nav-backdrop]');
                    var label = document.querySelector('[data-umu-nav-toggle-label]');
                    if (header) header.classList.toggle('is-nav-open', open);
                    if (panel) panel.classList.toggle('is-open', open);
                    if (toggle) {
                        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                        toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
                        toggle.classList.toggle('is-open', open);
                    }
                    if (backdrop) {
                        backdrop.hidden = true;
                        backdrop.classList.remove('is-visible');
                    }
                    if (label) label.textContent = open ? 'Fermer' : 'Menu';
                    document.body.classList.toggle('umu-nav-open', open);
                }

                function closeMenu() {
                    setMenuOpen(false);
                }

                document.addEventListener('click', function (e) {
                    var t = e.target;
                    if (!t || !t.closest) return;

                    var togglePwd = t.closest('[data-password-toggle-btn]');
                    if (togglePwd) {
                        e.preventDefault();
                        var wrap = togglePwd.closest('.umu-password');
                        var input = wrap ? wrap.querySelector('input') : null;
                        if (!input) return;
                        var show = input.type === 'password';
                        input.type = show ? 'text' : 'password';
                        var iconShow = togglePwd.querySelector('.umu-password__icon--show');
                        var iconHide = togglePwd.querySelector('.umu-password__icon--hide');
                        if (iconShow && iconHide) {
                            iconShow.hidden = show;
                            iconHide.hidden = !show;
                        }
                        togglePwd.setAttribute('aria-label', show ? 'Masquer le mot de passe' : 'Afficher le mot de passe');
                        return;
                    }

                    if (t.closest('[data-umu-nav-toggle]')) {
                        e.preventDefault();
                        var panel = document.querySelector('[data-umu-nav-panel]');
                        if (!panel) return;
                        setMenuOpen(!panel.classList.contains('is-open'));
                        return;
                    }

                    if (t.closest('[data-umu-nav-close]') || t.closest('[data-umu-nav-backdrop]')) {
                        e.preventDefault();
                        closeMenu();
                    }

                    var dashToggle = t.closest('[data-dash-menu-toggle]');
                    if (dashToggle) {
                        e.preventDefault();
                        var dashMenu = document.querySelector('[data-dash-nav]');
                        if (!dashMenu) return;
                        var dashOpen = !dashMenu.classList.contains('is-open');
                        dashMenu.classList.toggle('is-open', dashOpen);
                        dashToggle.setAttribute('aria-expanded', dashOpen ? 'true' : 'false');
                        dashToggle.setAttribute('aria-label', dashOpen ? 'Fermer le menu' : 'Ouvrir le menu');
                        dashToggle.classList.toggle('is-open', dashOpen);
                        document.body.classList.toggle('dash-menu-open', dashOpen);
                        return;
                    }

                    if (t.closest('[data-dash-nav] a.dash__link')) {
                        var openMenu = document.querySelector('[data-dash-nav].is-open');
                        var openToggle = document.querySelector('[data-dash-menu-toggle]');
                        if (openMenu) {
                            openMenu.classList.remove('is-open');
                            document.body.classList.remove('dash-menu-open');
                            if (openToggle) {
                                openToggle.setAttribute('aria-expanded', 'false');
                                openToggle.setAttribute('aria-label', 'Ouvrir le menu');
                                openToggle.classList.remove('is-open');
                            }
                        }
                    }
                }, true);
            })();
        </script>
    </body>
</html>
