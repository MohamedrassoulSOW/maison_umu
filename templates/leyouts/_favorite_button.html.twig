{% set liked = app.user and product.id in (app.session.get('favorites')|default([])) %}
{% set likesCount = product.likesCount|default(0) %}
{% if app.user %}
    <button type="button"
            class="umu-fav{% if liked %} is-active{% endif %}{% if class is defined and class %} {{ class }}{% endif %}"
            data-umu-favorite
            data-product-id="{{ product.id }}"
            data-favorite-url="{{ path('app_favorite_toggle', {id: product.id}) }}"
            aria-pressed="{{ liked ? 'true' : 'false' }}"
            aria-label="{{ liked ? 'Retirer des favoris' : 'Ajouter aux favoris' }} — {{ likesCount }} j’aime"
            title="{{ liked ? 'Retirer des favoris' : 'Ajouter aux favoris' }}">
        <svg class="umu-fav__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" aria-hidden="true">
            <path class="umu-fav__outline" fill="currentColor" d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143q.09.083.176.171a3 3 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15"/>
            <path class="umu-fav__fill" fill="currentColor" d="M8 1.314C12.438-3.248 23.534 4.735 8 15-7.534 4.736 3.562-3.248 8 1.314"/>
        </svg>
        <span class="umu-fav__count" data-umu-likes-count>{{ likesCount }}</span>
    </button>
{% else %}
    <a href="{{ path('app_login') }}"
       class="umu-fav{% if class is defined and class %} {{ class }}{% endif %}"
       aria-label="Connectez-vous pour ajouter aux favoris"
       title="Connectez-vous pour ajouter aux favoris">
        <svg class="umu-fav__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" aria-hidden="true">
            <path class="umu-fav__outline" fill="currentColor" d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143q.09.083.176.171a3 3 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15"/>
            <path class="umu-fav__fill" fill="currentColor" d="M8 1.314C12.438-3.248 23.534 4.735 8 15-7.534 4.736 3.562-3.248 8 1.314"/>
        </svg>
        <span class="umu-fav__count">{{ likesCount }}</span>
    </a>
{% endif %}
