<div class="umu-modal umu-welcome" data-umu-fav-welcome hidden>
    <div class="umu-modal__backdrop" data-umu-fav-welcome-close tabindex="-1"></div>
    <div class="umu-modal__dialog umu-welcome__dialog" role="dialog" aria-modal="true" aria-labelledby="umuFavWelcomeTitle">
        <button type="button" class="umu-modal__close" data-umu-fav-welcome-close aria-label="Fermer">✕</button>
        <div class="umu-welcome__body">
            <span class="umu-welcome__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                    <path d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143q.09.083.176.171a3 3 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15"/>
                </svg>
            </span>
            <p class="umu-welcome__brand">{{ brand_name|default('Maison UMU') }}</p>
            <h2 class="umu-welcome__title" id="umuFavWelcomeTitle">Gardez vos coups de cœur</h2>
            <p class="umu-welcome__text">
                Connectez-vous pour ajouter en favoris les pièces que vous souhaitez revoir,
                et pour finaliser vos commandes. Vos goûts nous aident à mieux vous guider.
            </p>
            <div class="umu-welcome__actions">
                {% if app.user %}
                    <a href="{{ path('app_home_page') }}#collection" class="umu-btn umu-btn--primary" data-umu-fav-welcome-close>
                        Parcourir la collection
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="umu-btn umu-btn--primary" data-umu-fav-welcome-close>
                        Se connecter
                    </a>
                    <a href="{{ path('app_register') }}" class="umu-btn umu-btn--ghost" data-umu-fav-welcome-close>
                        Créer un compte
                    </a>
                {% endif %}
                <button type="button" class="umu-btn umu-btn--ghost" data-umu-fav-welcome-close>
                    Plus tard
                </button>
            </div>
        </div>
    </div>
</div>
