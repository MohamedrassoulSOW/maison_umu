{% extends 'base.html.twig' %}

{% block title %}{{ subCategory.name }} — Maison UMU{% endblock %}

{% block body %}
<div class="umu-page-title">
    <h1>{{ subCategory.name }}</h1>
    <p>Les produits de cette sélection Maison UMU.</p>
</div>

<section class="umu-section" style="padding-top: 0;">
    <div class="umu-grid">
        {% for product in products %}
            {% include 'leyouts/_product_card.html.twig' with { product: product } %}
        {% else %}
            <div class="dash-empty-box" style="grid-column:1/-1;">Aucun produit disponible dans cette sélection.</div>
        {% endfor %}
    </div>
</section>
{% endblock %}
