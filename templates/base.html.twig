<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <script>
            (function () {
                try {
                    var saved = localStorage.getItem('umu-theme');
                    var dark = saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches);
                    document.documentElement.dataset.theme = dark ? 'dark' : 'light';
                    document.documentElement.style.colorScheme = dark ? 'dark' : 'light';
                } catch (e) {
                    document.documentElement.dataset.theme = 'light';
                }
            })();
        </script>
        <title>{% block title %}{{ brand_name|default('Maison UMU') }}{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        {# CSS boutique hors Asset Mapper : évite les 404 /assets/styles/app-XXXX.css en prod #}
        {% set umu_asset_v = '20260719f' %}
        <link rel="stylesheet" href="{{ asset('css/umu.css') }}?v={{ umu_asset_v }}">
        {% set favicon_path = brand_logo_path|default('images/logo.jpeg') %}
        {% set favicon_ext = favicon_path|split('.')|last|lower %}
        {% set favicon_type = favicon_ext in ['jpg', 'jpeg'] ? 'image/jpeg' : (favicon_ext == 'png' ? 'image/png' : (favicon_ext == 'webp' ? 'image/webp' : 'image/jpeg')) %}
        <link rel="icon" href="{{ asset(favicon_path) }}" type="{{ favicon_type }}">
        <link rel="apple-touch-icon" href="{{ asset(favicon_path) }}">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        {% block page_styles %}{% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% block nav %}
            {{ render(path('app_menu')) }}
        {% endblock %}

        {% include 'leyouts/_flash_message.html.twig' %}

        <main class="umu-main {% block main_class %}{% endblock %}">
            {% block body %}{% endblock %}
        </main>

        {% block footer %}
            {{ render(path('app_footer')) }}
        {% endblock %}

        {% include 'leyouts/_product_modal_shell.html.twig' %}
        {% include 'leyouts/_favorites_welcome.html.twig' %}

        {# Hors navbar : flottant en haut à droite, juste sous le header #}
        <button type="button"
                class="umu-theme-toggle umu-theme-toggle--float"
                data-umu-theme-toggle
                aria-label="Activer le mode sombre"
                title="Mode sombre">
            <svg class="umu-theme-toggle__moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278"/>
            </svg>
            <svg class="umu-theme-toggle__sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>
            </svg>
        </button>

        {# UI boutique : /js/umu-ui.js (hors Asset Mapper) #}
        <script src="{{ asset('js/umu-ui.js') }}?v={{ umu_asset_v|default('20260719d') }}" defer></script>
    </body>
</html>
