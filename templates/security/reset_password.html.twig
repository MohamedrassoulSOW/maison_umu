{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — {{ brand_name }}{% endblock %}

{% block body %}
<div class="umu-auth">
    <div class="umu-auth__panel">
        <div class="umu-auth__brand">
            <img src="{{ asset(brand_logo_path|default('images/logo.jpeg')) }}" alt="{{ brand_name }}">
        </div>
        <h1>Nouveau mot de passe</h1>
        <p style="text-align:center; color:rgba(26,33,28,0.65); margin-top:-0.5rem; margin-bottom:1.25rem;">
            Choisissez un nouveau mot de passe pour votre compte.
        </p>

        {{ form_start(resetForm, { attr: { 'data-turbo': 'false', class: 'umu-form' } }) }}
            <div class="umu-form__row">
                {{ form_label(resetForm.plainPassword.first) }}
                <div class="umu-password">
                    {{ form_widget(resetForm.plainPassword.first) }}
                    {% include 'leyouts/_password_toggle.html.twig' %}
                </div>
                {{ form_errors(resetForm.plainPassword.first) }}
            </div>
            <div class="umu-form__row">
                {{ form_label(resetForm.plainPassword.second) }}
                <div class="umu-password">
                    {{ form_widget(resetForm.plainPassword.second) }}
                    {% include 'leyouts/_password_toggle.html.twig' %}
                </div>
                {{ form_errors(resetForm.plainPassword.second) }}
            </div>
            {{ form_errors(resetForm.plainPassword) }}

            <button class="btn" type="submit">Enregistrer</button>
        {{ form_end(resetForm) }}
    </div>
</div>
{% endblock %}
