<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Maison UMU{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏠</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% block nav %}
            {{ render(path('app_menu')) }}
        {% endblock %}

        {% include 'leyouts/_flash_message.html.twig' %}

        <main class="umu-main">
            {% block body %}{% endblock %}
        </main>

        {% block footer %}
            {% include 'leyouts/footer.html.twig' %}
        {% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        <script>
            (function () {
                function closeMenu() {
                    var panel = document.querySelector('[data-umu-nav-panel]');
                    var toggle = document.querySelector('[data-umu-nav-toggle]');
                    var backdrop = document.querySelector('[data-umu-nav-backdrop]');
                    var label = document.querySelector('[data-umu-nav-toggle-label]');
                    if (panel) panel.classList.remove('is-open');
                    if (toggle) toggle.setAttribute('aria-expanded', 'false');
                    if (backdrop) { backdrop.hidden = true; backdrop.classList.remove('is-visible'); }
                    if (label) label.textContent = 'Menu';
                    document.body.classList.remove('umu-nav-open');
                }

                document.addEventListener('click', function (e) {
                    var t = e.target;
                    if (!t || !t.closest) return;

                    var togglePwd = t.closest('[data-password-toggle-btn]');
                    if (togglePwd) {
                        e.preventDefault();
                        var wrap = togglePwd.closest('.umu-password');
                        var input = wrap ? wrap.querySelector('input') : null;
                        if (!input) return;
                        var show = input.type === 'password';
                        input.type = show ? 'text' : 'password';
                        var iconShow = togglePwd.querySelector('.umu-password__icon--show');
                        var iconHide = togglePwd.querySelector('.umu-password__icon--hide');
                        if (iconShow && iconHide) {
                            iconShow.hidden = show;
                            iconHide.hidden = !show;
                        }
                        togglePwd.setAttribute('aria-label', show ? 'Masquer le mot de passe' : 'Afficher le mot de passe');
                        return;
                    }

                    if (t.closest('[data-umu-nav-toggle]')) {
                        e.preventDefault();
                        var panel = document.querySelector('[data-umu-nav-panel]');
                        var toggle = document.querySelector('[data-umu-nav-toggle]');
                        var backdrop = document.querySelector('[data-umu-nav-backdrop]');
                        var label = document.querySelector('[data-umu-nav-toggle-label]');
                        if (!panel || !toggle) return;
                        var open = !panel.classList.contains('is-open');
                        panel.classList.toggle('is-open', open);
                        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                        document.body.classList.toggle('umu-nav-open', open);
                        if (backdrop) {
                            backdrop.hidden = !open;
                            backdrop.classList.toggle('is-visible', open);
                        }
                        if (label) label.textContent = open ? 'Fermer' : 'Menu';
                        return;
                    }

                    if (t.closest('[data-umu-nav-backdrop]')) {
                        closeMenu();
                    }
                }, true);
            })();
        </script>
    </body>
</html>
